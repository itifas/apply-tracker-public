# Centralized secret/config file for local development
# Copy this file to backend/config/.env and fill real values.

DATABASE_URL="postgresql://postgres:postgres@db:5432/internship_tracker"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="internship_tracker"
NEXT_PUBLIC_APP_NAME="Internship Tracker"
AUTH_SECRET="replace-with-a-long-random-session-secret"
SEED_USERNAME="it"
SEED_PASSWORD="change-me-now"
SEED_EMAIL=""
SEED_FULL_NAME="IT"

# Optional future integrations
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
OUTLOOK_CLIENT_ID=""
OUTLOOK_CLIENT_SECRET=""
GMAIL_API_KEY=""
OUTLOOK_API_KEY=""
